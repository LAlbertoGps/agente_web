<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>RedGps - AI Assistant</title>
    <link rel="stylesheet" href="https://library.service24gps.com/css/library-style.css">
    <link rel="stylesheet" href="https://library.service24gps.com/platform-font/css/platform-font.css">
    <link rel="stylesheet" href="./src/css/chat.css">
</head>
<body>

    <header>
        <div class="logo">
            <span class="red">Red</span><span class="gps">Gps</span>
            <span style="font-weight: 300; font-size: 0.9rem; margin-left: 5px; opacity: 0.7;">| Assistant</span>
            <span class="engine-badge gemini" id="header-badge">Gemini</span>
        </div>
    </header>

    <main id="chat-container">
        <!-- Mensaje de Bienvenida -->
        <div class="message ai">
            <div class="avatar"><i data-lucide="radio" size="16"></i></div>
            <div class="bubble">
                Bienvenido al asistente inteligente de <strong>RedGps</strong>. ¿Cómo puedo ayudarte con el monitoreo de tus activos hoy? 
            </div>
        </div>
    </main>

    <!-- Overlay de Interacción por Voz -->
    <div id="voice-overlay">
        <div style="margin-bottom: 2rem;">
            <i data-lucide="radio" size="48" color="var(--brand-orange)" style="opacity: 0.8;"></i>
        </div>
        <h2 style="font-weight: 600; letter-spacing: -0.5px;">Modo de Voz Activo</h2>
        <div class="wave-container">
            <div class="wave-bar" style="animation-delay: 0.1s;"></div>
            <div class="wave-bar" style="animation-delay: 0.3s;"></div>
            <div class="wave-bar" style="animation-delay: 0.2s;"></div>
            <div class="wave-bar" style="animation-delay: 0.4s;"></div>
            <div class="wave-bar" style="animation-delay: 0.5s;"></div>
            <div class="wave-bar" style="animation-delay: 0.2s;"></div>
            <div class="wave-bar" style="animation-delay: 0.1s;"></div>
        </div>
        <p id="voice-status" style="color: var(--text-muted); font-size: 0.9rem; max-width: 250px;"></p>
        
       <div class="voice-buttons">
        <button class="stop-btn" id="close-voice">
            <i data-lucide="x" size="28"></i>
        </button>
        <button class="stop-btn" id="silent-voice">
            <i id="mic-icon" data-lucide="mic" size="28"></i>
        </button>
       </div>
        
    </div>

    <!-- Barra de herramientas inferior -->
    <div class="input-wrapper">
        <div class="input-area">
            <button class="icon-btn" id="mic-btn" style="color: var(--brand-orange)">
                <i data-lucide="mic" size="22"></i>
            </button>
          <input id="user-input" rows="1" placeholder="Escribe tu mensaje..."></input>
            <button class="icon-btn send-btn" id="send-btn">
                <i data-lucide="arrow-up-right" size="22"></i>
            </button>
        </div>
        <p class="disclaimer">Sistema de soporte asistido por IA - RedGps</p>
    </div>
  
    <div id="token-counter" style="font-size: 12px; color: #888; text-align: center; margin-bottom: 10px;">
        <span   >Entrada: <strong id="token-in">0</strong> <span style="opacity: 0.7;">(<span id="cost-in">$0.000000</span>)</span></span> | 
        <span>Salida: <strong id="token-out">0</strong> <span style="opacity: 0.7;">(<span id="cost-out">$0.000000</span>)</span></span> | 
        <span>Total: <strong id="token-total">0</strong> <span style="font-weight:bold;">(<span id="cost-total">$0.000000</span>)</span></span>
    </div>
</body> 
</html>